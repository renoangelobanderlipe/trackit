{
  "name": "trackit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @trackit/web dev",
    "dev:server": "cd apps/server && composer run dev",
    "build": "pnpm --filter @trackit/web build",
    "start": "pnpm --filter @trackit/web start",
    "lint": "biome check",
    "lint:server": "cd apps/server && vendor/bin/pint --dirty --format agent",
    "format": "biome format --write",
    "test:server": "cd apps/server && php artisan test --compact"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0"
  }
}
