# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
/out/

# production
/build

# laravel
apps/server/vendor/
apps/server/storage/*.key
apps/server/.env
apps/server/.env.backup
apps/server/.phpunit.cache

# node_modules (all workspaces)
node_modules

# claude/mcp
.claude/
.mcp.json

# laravel cache data
apps/server/storage/framework/cache/data/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
